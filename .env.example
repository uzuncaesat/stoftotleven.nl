# ============================================================
#  Stof tot Leven — environment variables
#  Copy this file to .env.local for local development.
#  In production (Vercel) set these in Project → Settings → Environment Variables.
# ============================================================

# Resend API key — create at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where the form messages should arrive
CONTACT_TO_EMAIL=info@stoftotleven.nl

# Sender shown in the inbox.
# Until your domain (stoftotleven.nl) is verified in Resend you MUST use
# the Resend sandbox sender below — verified domains let you switch to
# something like "Stof tot Leven <contact@stoftotleven.nl>".
CONTACT_FROM_EMAIL=Stof tot Leven <onboarding@resend.dev>
